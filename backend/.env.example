# Zhuji backend — environment variables
#
# Copy to backend/.env and fill in real values. JWT_SECRET is REQUIRED — the
# process refuses to start without one (no fallback in code).
#
# Generate a strong secret locally:
#   openssl rand -hex 32
#

# ── Required ────────────────────────────────────────────────
# At least 32 chars. Never commit a real value.
JWT_SECRET=replace-me-with-openssl-rand-hex-32-output-xxxxxxxx

# ── Optional (defaults shown) ───────────────────────────────
DATABASE_URL=postgresql+asyncpg://zhuji:devpassword@localhost:5432/zhuji

JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080  # 7 days

# CORS origins — JSON array
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","http://localhost:4173"]

LOG_LEVEL=INFO
