# Zhuji backend — local dev defaults
DATABASE_URL=postgresql+asyncpg://zhuji:devpassword@localhost:5432/zhuji

# JWT — REPLACE in prod, store in Key Vault
JWT_SECRET=dev-jwt-secret-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# CORS — comma-separated or JSON array
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

LOG_LEVEL=INFO
